{
  "name": "linter-config-monorepo",
  "private": true,
  "description": "Monorepo for @st1ggy/linter-config (packages/eslint).",
  "workspaces": [
    "packages/eslint"
  ],
  "scripts": {
    "lint": "npm run lint --workspace=@st1ggy/linter-config",
    "lint:eslint": "npm run lint:eslint --workspace=@st1ggy/linter-config",
    "lint:biome": "npm run lint:biome --workspace=@st1ggy/linter-config",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "changelog:dry": "conventional-changelog -p conventionalcommits"
  },
  "devDependencies": {
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/st1ggy/linter-config.git"
  },
  "license": "Apache-2.0",
  "author": "Dmitrii Bragin (st1ggy)"
}
