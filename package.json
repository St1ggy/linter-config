{
  "name": "@st1ggy/linter-config",
  "version": "6.3.1",
  "description": "ESLint, Prettier, and Stylelint shareable configs (sources under src/).",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/st1ggy/linter-config.git"
  },
  "keywords": [
    "eslint",
    "prettier",
    "stylelint"
  ],
  "author": "Dmitrii Bragin (st1ggy)",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/St1ggy/linter-config/issues"
  },
  "homepage": "https://github.com/St1ggy/linter-config/tree/main#readme",
  "bin": {
    "@st1ggy/linter-config": "./scripts/linter-init.mjs"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@inquirer/core": "^10.3.2",
    "@inquirer/prompts": "^7.10.1",
    "@next/eslint-plugin-next": "^16.2.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.0.0 || ^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-svelte": "^3.17.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "find-up-simple": "^1.0.1",
    "minimist": "^1.2.8",
    "ora": "^8.2.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.0.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "types": "./index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./eslint-next": {
      "types": "./index.d.ts",
      "import": "./src/eslint/eslint.config.next.js",
      "default": "./src/eslint/eslint.config.next.js"
    },
    "./eslint-react": {
      "types": "./index.d.ts",
      "import": "./src/eslint/eslint.config.react.js",
      "default": "./src/eslint/eslint.config.react.js"
    },
    "./eslint-svelte": {
      "types": "./index.d.ts",
      "import": "./src/eslint/eslint-svelte.config.js",
      "default": "./src/eslint/eslint-svelte.config.js"
    },
    "./eslint-common": {
      "types": "./index.d.ts",
      "import": "./src/eslint/eslint.config.common.js",
      "default": "./src/eslint/eslint.config.common.js"
    },
    "./prettier-common": {
      "types": "./index.d.ts",
      "import": "./src/prettier/prettier.config.common.js",
      "default": "./src/prettier/prettier.config.common.js"
    },
    "./prettier-svelte": {
      "types": "./index.d.ts",
      "import": "./src/prettier/prettier-svelte.config.js",
      "default": "./src/prettier/prettier-svelte.config.js"
    },
    "./stylelint-scss": {
      "types": "./index.d.ts",
      "import": "./src/stylelint/stylelint.config.scss.js",
      "default": "./src/stylelint/stylelint.config.scss.js"
    }
  },
  "files": [
    "index.d.ts",
    "src",
    "scripts",
    "data",
    "docs"
  ],
  "scripts": {
    "lint": "eslint . && stylelint \"src/**/*.{css,scss}\" --config ./src/stylelint/stylelint.config.scss.js --allow-empty-input && prettier --check .",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{css,scss}\" --config ./src/stylelint/stylelint.config.scss.js --allow-empty-input",
    "lint:prettier": "prettier --check .",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,scss}\" --config ./src/stylelint/stylelint.config.scss.js --fix --allow-empty-input && prettier --write .",
    "lint:fix:eslint": "npm run lint:fix",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "changelog:dry": "conventional-changelog -p conventionalcommits",
    "publish:npm": "npm publish --access public",
    "inventory": "node ./scripts/inventory.mjs",
    "config:init": "node ./scripts/linter-init.mjs init --common --dir ./examples/init-smoke",
    "config:reinit": "node ./scripts/linter-init.mjs reinit --common --dir ./examples/init-smoke",
    "config:create": "node ./scripts/linter-init.mjs create --common --dir ./examples/init-smoke",
    "config:remove-current": "bash ./scripts/remove-current.sh"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0",
    "next": "^16.0.0",
    "prettier": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "stylelint": "^17.0.0",
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-migrate": "^4.4.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.0.0"
  }
}
